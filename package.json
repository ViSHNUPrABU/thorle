{
  "name": "thorle",
  "version": "1.0.0",
  "description": "Server-driven UI component library for building dynamic dashboards and monitoring interfaces from JSON configurations",
  "keywords": [
    "server-driven-ui",
    "sdui",
    "dashboard",
    "monitoring",
    "react-components",
    "dynamic-ui",
    "json-driven",
    "config-driven"
  ],
  "homepage": "https://github.com/ViSHNUPrABU/thorle#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ViSHNUPrABU/thorle.git"
  },
  "bugs": {
    "url": "https://github.com/ViSHNUPrABU/thorle/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "import": "./dist/components.js",
      "require": "./dist/components.cjs"
    },
    "./sdui": {
      "types": "./dist/sdui.d.ts",
      "import": "./dist/sdui.js",
      "require": "./dist/sdui.cjs"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js",
      "require": "./dist/utils.cjs"
    },
    "./services": {
      "types": "./dist/services.d.ts",
      "import": "./dist/services.js",
      "require": "./dist/services.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": true,
  "scripts": {
    "build": "tsc && vite build",
    "build:storybook": "storybook build",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "@mantine/core": ">=7.0.0",
    "@mantine/hooks": ">=7.0.0",
    "@tanstack/react-query": ">=5.0.0",
    "ajv": ">=8.0.0",
    "axios": ">=1.0.0",
    "echarts": ">=5.0.0",
    "echarts-for-react": ">=3.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-grid-layout": ">=1.3.0",
    "zod": ">=3.0.0",
    "zustand": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "echarts": {
      "optional": true
    },
    "echarts-for-react": {
      "optional": true
    },
    "mantine-react-table": {
      "optional": true
    },
    "react-grid-layout": {
      "optional": true
    }
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.0",
    "@eslint/js": "^9.36.0",
    "@mantine/core": "^7.17.0",
    "@mantine/hooks": "^7.17.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/addon-interactions": "^8.4.0",
    "@storybook/addon-links": "^8.4.0",
    "@storybook/blocks": "^8.4.0",
    "@storybook/react": "^8.4.0",
    "@storybook/react-vite": "^8.4.0",
    "@storybook/test": "^8.4.0",
    "@tanstack/react-query": "^5.90.6",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^15.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-grid-layout": "^1.3.5",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^2.1.0",
    "ajv": "^8.17.1",
    "autoprefixer": "^10.4.27",
    "axios": "^1.13.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "eslint-plugin-storybook": "^0.11.0",
    "globals": "^16.4.0",
    "jsdom": "^25.0.0",
    "playwright": "^1.59.1",
    "postcss": "^8.5.8",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^2.2.3",
    "react-resizable": "^3.1.3",
    "storybook": "^8.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^6.3.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.8"
  },
  "optionalDependencies": {
    "mantine-react-table": "^1.3.4"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.41.1"
  }
}
